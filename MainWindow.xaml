<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DiagFramework"
        Height="820" Width="1320" MinHeight="760" MinWidth="1180"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="230"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,8">
      <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
        <Button Name="btnReloadModules" Width="120" Height="32" Margin="0,0,8,0"/>
        <Button Name="btnScan" Width="170" Height="32" Margin="0,0,8,0"/>
        <Button Name="btnRunSelected" Width="210" Height="32" Margin="0,0,8,0"/>
        <Button Name="btnRollbackSelected" Width="170" Height="32" Margin="0,0,8,0"/>
        <CheckBox Name="chkWhatIf" VerticalAlignment="Center" Margin="10,0,16,0" IsChecked="True"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
        <Button Name="btnSearchUpdates" Width="170" Height="32" Margin="0,0,8,0"/>
        <Button Name="btnInstallUpdates" Width="190" Height="32"/>
      </StackPanel>
    </DockPanel>

    <Border Grid.Row="1" BorderThickness="1" BorderBrush="#CCCCCC" Padding="8" Margin="0,0,0,10">
      <DockPanel LastChildFill="False">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
          <TextBlock Name="lblTargetKB" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <TextBox Name="txtTargetKB" Width="120" Height="26" Text="KB5089573" Margin="0,0,16,0"/>
          <TextBlock Name="lblDaysBack" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <TextBox Name="txtDaysBack" Width="55" Height="26" Text="30" Margin="0,0,16,0"/>
          <Button Name="btnAiLogPackage" Width="220" Height="32" Margin="0,0,8,0"/>
          <Button Name="btnEvidencePackage" Width="235" Height="32" Margin="0,0,8,0"/>
          <Button Name="btnOpenLogs" Width="130" Height="32"/>
        </StackPanel>
        <TextBlock Name="txtTopHint" DockPanel.Dock="Right" VerticalAlignment="Center" TextWrapping="Wrap" Width="360"/>
      </DockPanel>
    </Border>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="3*"/>
        <ColumnDefinition Width="2*"/>
        <ColumnDefinition Width="2*"/>
      </Grid.ColumnDefinitions>

      <GroupBox Name="grpModules" Grid.Column="0" Margin="0,0,8,0">
        <ListView Name="lvResults" SelectionMode="Extended">
          <ListView.View>
            <GridView>
              <GridViewColumn Header="Választ" Width="70">
                <GridViewColumn.CellTemplate>
                  <DataTemplate>
                    <CheckBox IsChecked="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                  </DataTemplate>
                </GridViewColumn.CellTemplate>
              </GridViewColumn>
              <GridViewColumn Header="Modul" DisplayMemberBinding="{Binding Name}" Width="260"/>
              <GridViewColumn Header="Súly" DisplayMemberBinding="{Binding Severity}" Width="80"/>
              <GridViewColumn Header="Állapot" DisplayMemberBinding="{Binding Status}" Width="220"/>
            </GridView>
          </ListView.View>
        </ListView>
      </GroupBox>

      <GroupBox Name="grpSummary" Grid.Column="1" Margin="0,0,8,0">
        <TextBox Name="txtSelectedSummary" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="8"/>
      </GroupBox>

      <GroupBox Name="grpRecommendedAction" Grid.Column="2">
        <TextBox Name="txtSelectedAction" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="8"/>
      </GroupBox>
    </Grid>

    <Grid Grid.Row="3" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <GroupBox Name="grpLog" Grid.Column="0" Margin="0,0,8,0">
        <TextBox Name="txtLog" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"/>
      </GroupBox>
      <GroupBox Name="grpUsageNotes" Grid.Column="1">
        <TextBlock Name="txtUsageNotes" TextWrapping="Wrap" Margin="8"/>
      </GroupBox>
    </Grid>

    <StatusBar Grid.Row="4" Margin="0,8,0,0">
      <StatusBarItem>
        <TextBlock Name="txtStatus"/>
      </StatusBarItem>
    </StatusBar>
  </Grid>
</Window>
